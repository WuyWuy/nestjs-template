model User {
    id Int @id @default(autoincrement()) 
    email String @unique 
    password String 
    active Boolean 
    userRoles          UserRole[]
    name String @default("") 
}

model UserRole {
    id Int @id @default(autoincrement())
    user   User @relation(fields: [userID], references: [id])
    userID Int
    role Role 
} 